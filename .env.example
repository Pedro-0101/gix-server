# Copie para .env e preencha. Na Railway, defina como variáveis do serviço.

# Porta (a Railway injeta automaticamente; local cai pra 8080 se vazio)
PORT=8080

# Postgres (Railway fornece DATABASE_URL no plugin de Postgres)
DATABASE_URL=postgres://user:pass@localhost:5432/gix?sslmode=disable

# Segredo p/ assinar os JWT de auth (gere um valor longo e aleatório)
JWT_SECRET=

# Chave da OpenRouter — vive SÓ no servidor; nenhum canal a vê (fase 2: relay de IA)
OPENROUTER_API_KEY=
